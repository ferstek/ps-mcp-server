{
  "rewrites": [
    { "source": "/.well-known/:path*", "destination": "/api/.well-known/:path*" },
    { "source": "/authorize",          "destination": "/api/authorize" },
    { "source": "/oauth/token",        "destination": "/api/oauth/token" },
    { "source": "/token",              "destination": "/api/oauth/token" }
  ],
  "functions": {
    "api/[transport].js": { "maxDuration": 60 }
  }
}
